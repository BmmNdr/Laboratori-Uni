BEGIN
  read R3;
  if R3 < 0 then
    R3 := 0 - R3;
  else
    skip;
  fi;
  write R3 * 2;
END

BEGIN
  read R0;
  read R1;
  if R0 < R1 then
    R2 := R1;
  else
    R2 := R0;
  fi;
  write R2;
END

BEGIN
  read R1;
  R2 := 1;
  R3 := R2;
  while R2 < R1 do
    R3 := R3 + (R2 * R2);
    R2 := R2 + 1;
  done;
  write R3;
END
